    "db:generate": "npm run db:generate --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2",
    "@types/node": "^22.13.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
