{
  "name": "@cubiqport/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@cubiqport/shared": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@fastify/websocket": "^10.0.1",
    "bcryptjs": "^2.4.3",
    "cloudflare": "^3.5.0",
    "drizzle-orm": "^0.38.4",
    "fastify": "^4.29.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "node-ssh": "^13.2.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^20.4.0",
    "undici": "^6.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
